# URL do seu Frontend (para onde o backend vai redirecionar ou aceitar requisições)
FRONTEND_URL= 
VUE_APP_API_URL= 

# Configurações do Ambiente (development ou production)
ENVIRONMENT=

# Configurações de Banco de Dados (Se no futuro você mudar do SQLite para o Supabase/Neon)
